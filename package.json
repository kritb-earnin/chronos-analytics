{
  "name": "chronos-analytics",
  "version": "0.1.0",
  "description": "Event Sourcing for the Frontend — high-fidelity tracking and Time Machine replay",
  "type": "module",
  "main": "./dist/chronos-analytics.cjs",
  "module": "./dist/chronos-analytics.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/chronos-analytics.js",
      "require": "./dist/chronos-analytics.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "dev:demo1": "cd examples/demo && pnpm dev",
    "dev:demo2": "cd examples/demo-simple && pnpm dev"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "packageManager": "pnpm@9.14.0"
}
